# Keep the build context small and free of secrets / local state.
.git
.gitignore
.venv
venv
env
__pycache__
*.pyc
.pytest_cache
.mypy_cache
.ruff_cache

# Local secrets and runtime data — never bake these into the image.
.env
*.env
!.env.example
instance/
logs/
*.db
*.sqlite*

# Docs / editor cruft
*.md
.vscode
.idea
