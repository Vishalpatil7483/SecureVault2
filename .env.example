# ============================================================
# SecureVault 2.0 — Example environment configuration
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file.
# ============================================================

# Which config class to load: development | testing | production
FLASK_CONFIG=development

# Strong random secret for session signing.
# Optional in development (a throwaway dev key is used if unset).
# REQUIRED in production: must be >= 32 chars or the app refuses to start.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Networking
HOST=127.0.0.1
PORT=5000

# Database connection string.
# Leave unset to use the default local SQLite database in instance/.
# Example Postgres: postgresql+psycopg://user:pass@localhost:5432/securevault
# DATABASE_URL=

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG
